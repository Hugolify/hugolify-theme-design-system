{
  "pagination-between": {
    "fontSize": {
      "$type": "dimension",
      "$value": "{fontSize.lg}"
    },
    "fontWeight": {
      "$type": "fontWeight",
      "$value": "{fontWeight.bold}"
    },
    "margin": {
      "blockStart": {
        "$type": "dimension",
        "$value": "{spacing.lg}"
      }
    },
    "padding": {
      "block": {
        "$type": "dimension",
        "$value": "{spacing.lg}"
      }
    },
    "item": {
      "padding": {
        "$type": "dimension",
        "$value": "0"
      }
    },
    "link": {
      "border": {
        "radius": {
          "$type": "dimension",
          "$value": "{radius.control}"
        },
        "style": {
          "$type": "string",
          "$value": "{border.style.normal}"
        },
        "width": {
          "$type": "dimension",
          "$value": "0"
        }
      },
      "color": {
        "background": {
          "default": {
            "$type": "color",
            "$value": "transparent"
          },
          "hover": {
            "$type": "color",
            "$value": "{color.background.muted.default}"
          }
        },
        "border": {
          "$type": "color",
          "$value": "{color.border.default}"
        },
        "textDecoration": {
          "default": {
            "$type": "color",
            "$value": "transparent"
          },
          "hover": {
            "$type": "color",
            "$value": "transparent"
          }
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{spacing.sm}"
      },
      "padding": {
        "inline": {
          "$type": "dimension",
          "$value": "{spacing.sm}"
        },
        "block": {
          "$type": "dimension",
          "$value": "{spacing.sm}"
        }
      },
      "shadow": {
        "default": {
          "$type": "shadow",
          "$value": "{shadow.none}"
        },
        "hover": {
          "$type": "shadow",
          "$value": "{shadow.sm}"
        }
      }
    }
  }
}
