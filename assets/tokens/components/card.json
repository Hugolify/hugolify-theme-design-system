{
  "card": {
    "border": {
      "width": {
        "$value": "{border.width.none}",
        "$type": "dimension"
      }
    },
    "color": {
      "background": {
        "$value": "{color.background.muted}",
        "$type": "color"
      }
    },
    "fontSize": {
      "$value": "{font.size.xs}",
      "$type": "dimension"
    },
    "media": {
      "color": {
        "background": {
          "$value": "transparent",
          "$type": "color"
        }
      }
    },
    "transition": {
      "$value": "{transition.normal}",
      "$type": "string"
    }
  }
}
