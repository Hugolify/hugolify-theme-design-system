{
  "card": {
    "border": {
      "radius": {
        "$value": "{item.border.radius}",
        "$type": "dimension"
      },
      "style": {
        "$value": "{item.border.style}",
        "$type": "strokeStyle"
      },
      "width": {
        "$value": "{border.width.none}",
        "$type": "dimension"
      }
    },
    "color": {
      "background": {
        "$value": "{color.background.muted}",
        "$type": "color"
      },
      "border": {
        "$value": "{item.color.border}",
        "$type": "color"
      },
      "text": {
        "default": {
          "$value": "{item.color.text.default}",
          "$type": "color"
        },
        "muted": {
          "$value": "{item.color.text.muted}",
          "$type": "color"
        }
      }
    },
    "media": {
      "color": {
        "background": {
          "$value": "transparent",
          "$type": "color"
        }
      }
    },
    "transition": {
      "$value": "{transition.normal}",
      "$type": "string"
    }
  }
}
