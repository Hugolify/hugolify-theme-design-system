{
  "screenshot": {
    "border": {
      "radius": {
        "$type": "dimension",
        "$value": "{radius.sm}"
      }
    },
    "bar": {
      "color": {
        "background": {
          "$type": "color",
          "$value": "#D9D9D9"
        }
      },
      "height": {
        "$type": "dimension",
        "$value": "1.25rem"
      }
    },
    "dot": {
      "size": {
        "$type": "dimension",
        "$value": "0.5rem"
      },
      "offset": {
        "top": {
          "$type": "dimension",
          "$value": "0.375rem"
        }
      },
      "color": {
        "red": {
          "$type": "color",
          "$value": "#EE0E00"
        },
        "yellow": {
          "$type": "color",
          "$value": "#EEAB00"
        },
        "green": {
          "$type": "color",
          "$value": "#0EB000"
        }
      }
    },
    "shadow": {
      "$type": "shadow",
      "$value": "{shadow.center.md}"
    },
    "figcaption": {
      "padding": {
        "blockStart": {
          "$type": "dimension",
          "$value": "{spacing.xs}"
        }
      }
    }
  }
}
